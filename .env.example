# ============================================================================
# AumOS Quantum Readiness — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# All standard AumOS variables are inherited from aumos-common.
# Repo-specific variables use the AUMOS_QUANTUM_ prefix.
# ============================================================================

# --- Database ---
AUMOS_DATABASE_URL=postgresql+asyncpg://aumos:aumos_dev@localhost:5432/aumos

# --- Keycloak / Auth ---
AUMOS_KEYCLOAK_URL=http://localhost:8080
AUMOS_KEYCLOAK_REALM=aumos
AUMOS_KEYCLOAK_CLIENT_ID=aumos-quantum-readiness

# --- Kafka ---
AUMOS_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# --- Redis ---
AUMOS_REDIS_URL=redis://localhost:6379/0

# --- Service ---
AUMOS_ENVIRONMENT=development
AUMOS_LOG_LEVEL=INFO

# --- Quantum Readiness Specific ---
AUMOS_QUANTUM_PQC_KYBER_KEY_SIZE=1024
AUMOS_QUANTUM_PQC_DILITHIUM_SECURITY_LEVEL=3
AUMOS_QUANTUM_PQC_HYBRID_MODE_ENABLED=true
AUMOS_QUANTUM_HARVEST_RISK_THRESHOLD=0.75
AUMOS_QUANTUM_HARVEST_SCAN_INTERVAL_HOURS=24
AUMOS_QUANTUM_NIST_PQC_STANDARD_VERSION=FIPS-203
AUMOS_QUANTUM_COMPLIANCE_CHECK_TIMEOUT_SECONDS=30
